*.apk
*.aab
*.ap_
*.aar

# Gradle / build outputs
.gradle/
build/
**/build/

# Local configuration (SDK path, secrets)
local.properties

# Android Studio / IntelliJ
*.iml
.idea/
!.idea/codeStyles/
!.idea/runConfigurations.xml
!.idea/deploymentTargetDropDown.xml
!.idea/gradle.xml
!.idea/misc.xml
!.idea/vcs.xml
